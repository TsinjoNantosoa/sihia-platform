VITE_API_URL=http://127.0.0.1:8000
VITE_USE_MOCKS=false
VITE_CLIENT_ID=sihia
# Token chatbot (doit correspondre à CHATBOT_API_TOKEN backend)
VITE_CHATBOT_API_TOKEN=

# Docker Compose — pgAdmin (http://localhost:5050)
PGADMIN_DEFAULT_EMAIL=admin@sihia.health
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050
# Port hôte Postgres SIH IA (évite conflit avec PostgreSQL Windows sur 5432)
POSTGRES_PORT=5434
