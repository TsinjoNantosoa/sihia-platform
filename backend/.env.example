# Backend SIH IA
ENVIRONMENT=development
JWT_SECRET=change-me-in-production-please-use-32-plus-bytes
# SQLite local (défaut)
DATABASE_URL=app.db
# PostgreSQL pilote (docker compose) — port hôte 5434 par défaut, 5435 si 5434 occupé :
#   POSTGRES_PORT=5435 docker compose up -d postgres
# Copier ce fichier vers backend/.env puis décommenter une ligne ci-dessous.
# Windows local (pg8000, recommandé) :
# DATABASE_URL=postgresql+pg8000://sihia:sihia@localhost:5434/sihia
# Si port 5434 déjà pris (autre Postgres Docker) :
# DATABASE_URL=postgresql+pg8000://sihia:sihia@localhost:5435/sihia
# Linux / Docker :
# DATABASE_URL=postgresql://sihia:sihia@localhost:5434/sihia
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=7
MAX_REFRESH_SESSIONS=3
AUDIT_LOG_PATH=logs/audit.jsonl
ML_USE_PROPHET=true
REMINDER_EMAIL_MODE=log
REMINDER_SMS_MODE=log
REMINDER_HOURS_BEFORE=24
REMINDER_LOG_PATH=logs/reminders.jsonl
# --- SMTP réel (REMINDER_EMAIL_MODE=smtp) ---
# Pilote local avec MailHog : docker compose --profile mailhog up -d mailhog
# UI MailHog : http://localhost:8025 — SMTP : localhost:1025
# REMINDER_EMAIL_MODE=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USE_TLS=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@sihia.health
# Production (exemple) :
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# Twilio (REMINDER_SMS_MODE=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
PIPELINE_IMPORT_DIR=data/imports
PIPELINE_STALE_HOURS=24

# --- Chatbot RAG (OpenAI + widget H4H) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CHATBOT_API_TOKEN=
CHATBOT_QUERY_RATE_LIMIT=20
CHATBOT_AUDIT_LOG_PATH=logs/chatbot.jsonl
