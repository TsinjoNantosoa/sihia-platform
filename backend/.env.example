# Backend SIH IA
ENVIRONMENT=development
JWT_SECRET=change-me-in-production-please-use-32-plus-bytes
JWT_ALGORITHM=HS256
# SQLite local (défaut)
DATABASE_URL=app.db
# PostgreSQL pilote :
# DATABASE_URL=postgresql+pg8000://sihia:sihia@localhost:5434/sihia

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
ACCESS_TOKEN_EXP_MINUTES=60
REFRESH_TOKEN_EXP_DAYS=7
MAX_REFRESH_SESSIONS=5
AUDIT_LOG_PATH=logs/audit.jsonl
ML_USE_PROPHET=true

# --- OAuth Google / Microsoft (mode réel quand ID + secret sont renseignés) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# --- Email (reset password / rappels) ---
# EMAIL_MODE=log  → écrit dans logs/reminders.jsonl (dev)
# EMAIL_MODE=smtp → envoi réel (Gmail App Password recommandé)
EMAIL_MODE=log
PASSWORD_RESET_EXP_MINUTES=60
# Alias historique (si EMAIL_MODE absent) :
REMINDER_EMAIL_MODE=log
REMINDER_SMS_MODE=log
REMINDER_HOURS_BEFORE=24
REMINDER_LOG_PATH=logs/reminders.jsonl

# SMTP réel (EMAIL_MODE=smtp) — exemple Gmail :
# EMAIL_MODE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=votre@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=SIH IA <noreply@sihia.health>

# Pilote local MailHog :
# EMAIL_MODE=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USE_TLS=false
# SMTP_FROM=noreply@sihia.health

SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SIH IA <noreply@sihia.health>

# Twilio (REMINDER_SMS_MODE=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

PIPELINE_IMPORT_DIR=data/imports
PIPELINE_STALE_HOURS=24

# --- Chatbot RAG ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
CHATBOT_API_TOKEN=
CHATBOT_QUERY_RATE_LIMIT=20
CHATBOT_AUDIT_LOG_PATH=logs/chatbot.jsonl
